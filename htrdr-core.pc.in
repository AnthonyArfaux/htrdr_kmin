# Used for local building only
Requires: rsys >= @RSYS_VERSION@
Requires.private:\
 aw >= @AW_VERSION@,\
 @MPI_PC@ >= @MPI_VERSION@,\
 mrumtl >= @MRUMTL_VERSION@,\
 s3d >= @S3D_VERSION@,\
 scam >= @SCAM_VERSION@,\
 ssf >= @SSF_VERSION@,\
 star-sp >= @SSP_VERSION@
Name: htrdr-core
Description: htrdr Core
Version: @VERSION@
Libs: -L. -lhtrdr-core
Libs.private: -lm -fopenmp
CFlags: -Isrc
