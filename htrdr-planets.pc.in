# Used for local building only
Requires: rsys >= @RSYS_VERSION@
Requires.private:\
 htrdr-core >= @VERSION@,\
 rnatm > @RNATM_VERSION@,\
 rngrd > @RNGRD_VERSION@,\
 s3d >= @S3D_VERSION@,\
 sbuf >= @SBUF_VERSION@,\
 scam >= @SCAM_VERSION@,\
 ssf >= @SSF_VERSION@,\
 star-sp >= @SSP_VERSION@,\
 svx >= @SVX_VERSION@
Name: htrdr-planets
Description: htrdr Planets
Version: @VERSION@
Libs: -L. -lhtrdr-planets
Libs.private: -lm
CFlags: -DHTRDR_BUILD_PLANETS -Isrc
