# Used for local building only
Requires: rsys >= @RSYS_VERSION@
Requires.private:\
 htrdr-core >= @VERSION@,\
 htsky >= @HTSKY_VERSION@,\
 s3d >= @S3D_VERSION@,\
 scam >= @SCAM_VERSION@,\
 ssf >= @SSF_VERSION@,\
 star-sp >= @SSP_VERSION@,\
 svx >= @SVX_VERSION@
Name: htrdr-atmosphere
Description: htrdr Atmosphere
Version: @VERSION@
Libs: -L. -lhtrdr-atmosphere
Libs.private: -lm
CFlags: -DHTRDR_BUILD_ATMOSPHERE -Isrc
